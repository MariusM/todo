{
  "name": "todo",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "e2e"
  ],
  "scripts": {
    "dev:client": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w client && npm run build -w server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run test -w e2e"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18"
  }
}
